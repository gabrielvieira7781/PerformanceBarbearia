// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// Tabela de Barbearias (SaaS)
// ==========================================
model Barbershop {
  id        String   @id @default(cuid())
  name      String
  document  String   
  address   String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  clients           Client[]
  serviceTypes      ServiceType[]
  serviceLogs       ServiceLog[]
  financialRecords  FinancialRecord[]
  subscriptionPlans SubscriptionPlan[]
}

// ==========================================
// Tabela de Usuários (Barbeiros e Admin)
// ==========================================
model User {
  id                      String       @id @default(cuid())
  barbershopId            String?
  name                    String
  email                   String       @unique
  password                String
  role                    String       @default("BARBER") 
  permissions             String[]     @default([])       
  isActive                Boolean      @default(true)
  isVerified              Boolean      @default(false)
  verificationCode        String?
  verificationCodeExpires DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  barbershop Barbershop?  @relation(fields: [barbershopId], references: [id])
  services   ServiceLog[]
  commissionRate Float?   @default(50)       // Porcentagem de comissão (Ex: 50%)
  paymentCycle   String?  @default("WEEKLY") // Ciclo: DAILY, WEEKLY, BIWEEKLY, MONTHLY
}

// ==========================================
// Tabela de Planos de Assinatura (Clube)
// ==========================================
model SubscriptionPlan {
  id           String   @id @default(cuid())
  barbershopId String
  name         String
  price        Float
  maxCuts      Int      // Quantidade liberada por ciclo
  billingCycle String   @default("MONTHLY") // NOVO: MONTHLY, QUARTERLY, SEMIANNUAL, ANNUAL
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  services     ServiceType[] // NOVO: Serviços incluídos neste plano
  clients      Client[]
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])
}

// ==========================================
// Tabela de Clientes
// ==========================================
model Client {
  id                String   @id @default(cuid())
  barbershopId      String?
  name              String
  phone             String
  isActive          Boolean  @default(true)
  
  parentId          String?
  parent            Client?  @relation("FamilyLink", fields: [parentId], references: [id])
  dependents        Client[] @relation("FamilyLink")

  // Clube de Assinatura Atualizado
  planId            String?
  plan              SubscriptionPlan? @relation(fields: [planId], references: [id])
  cutsUsedThisMonth Int      @default(0) // RESTAURADO: Nome original para não perder dados
  planExpiresAt     DateTime?            // NOVO: Data exata em que o plano vence!

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  loyaltyPoints Float @default(0)
  loyaltyStamps Int   @default(0)

  barbershop        Barbershop?  @relation(fields: [barbershopId], references: [id])
  services          ServiceLog[]
}

// ==========================================
// Tabela de Catálogo de Serviços e Preços
// ==========================================
model ServiceType {
  id           String   @id @default(cuid())
  barbershopId String?
  name         String
  description  String?  
  price        Float
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  plans        SubscriptionPlan[] // NOVO: Planos que aceitam este serviço

  barbershop   Barbershop?  @relation(fields: [barbershopId], references: [id])
  logs         ServiceLog[]
}

// ==========================================
// Tabela de Lançamentos de Serviços
// ==========================================
model ServiceLog {
  id            String   @id @default(cuid())
  barbershopId  String?
  userId        String
  clientId      String
  serviceTypeId String?
  priceCharged  Float
  paymentMethod String
  status        String   @default("COMPLETED")
  date          DateTime @default(now())
  isCommissionPaid Boolean @default(false) // NOVO: Controla se a comissão já foi paga ao barbeiro
  barbershop    Barbershop?  @relation(fields: [barbershopId], references: [id])
  user          User         @relation(fields: [userId], references: [id])
  client        Client       @relation(fields: [clientId], references: [id])
  serviceType   ServiceType?  @relation(fields: [serviceTypeId], references: [id])
  productId     String?
  product       Product? @relation(fields: [productId], references: [id])
}

// ==========================================
// Tabela de Gestão Financeira (Controle de Caixa)
// ==========================================
model FinancialRecord {
  id           String   @id @default(cuid())
  barbershopId String?
  type         String   
  amount       Float
  description  String
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  status       String?   @default("PAID")    // "PAID" (Pago) ou "PENDING" (Pendente)
  dueDate      DateTime? @default(now())     // Data de Vencimento
  category     String?   @default("VARIAVEL")
  paidAt       DateTime?  // NOVO: Data em que a conta foi efetivamente paga

  barbershop   Barbershop?  @relation(fields: [barbershopId], references: [id])
}

// Configurações gerais da Barbearia
model BarbershopSettings {
  id                  String   @id @default(cuid())
  barbershopId        String   @unique
  allowBarberExpenses Boolean  @default(false) // O botão de liga/desliga

  whatsappInstanceName String? 
  whatsappApiKey       String? 
  isWhatsappConnected  Boolean @default(false)
  
  // Fidelidade: Cashback (Pontos)
  enablePointsLoyalty Boolean @default(false)
  pointsMultiplier    Float   @default(1.0)  // Ganha quantos pontos a cada R$ 1? (Ex: 1)
  pointsDiscountValue Float   @default(0.05) // Quanto vale cada ponto? (Ex: 0.05 = 5 centavos)

  // Fidelidade: Cartão de Selos
  enableStampsLoyalty     Boolean @default(false)
  stampsRequiredForReward Int     @default(10) // Ex: A cada 10 cortes
  stampRewardDescription  String  @default("1 Corte Grátis") // O que ele ganha
  
  updatedAt           DateTime @updatedAt
}

// Tabela exclusiva para os gastos pessoais do Barbeiro (não entra no DRE da barbearia)
model BarberExpense {
  id           String   @id @default(cuid())
  userId       String   // ID do Barbeiro
  barbershopId String   
  amount       Float
  description  String
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
}

model Product {
  id           String   @id @default(cuid())
  barbershopId String
  name         String
  
  price        Float    // Preço de Venda (Ex: R$ 35.00)
  costPrice    Float    @default(0) // NOVO: Preço de Custo (Ex: R$ 15.00)
  
  stock        Int      @default(0) // Quantidade atual na prateleira
  minStock     Int      @default(5) // NOVO: Alerta quando chegar nessa quantidade
  
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  serviceLogs  ServiceLog[]
}