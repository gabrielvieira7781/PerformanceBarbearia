// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// Tabela de Barbearias (SaaS)
// ==========================================
model Barbershop {
  id        String   @id @default(cuid())
  name      String
  document  String   // CNPJ ou CPF
  address   String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  clients          Client[]
  serviceTypes     ServiceType[]
  serviceLogs      ServiceLog[]
  financialRecords FinancialRecord[]
}

// ==========================================
// Tabela de Usuários (Barbeiros e Admin)
// ==========================================
model User {
  id                      String       @id @default(cuid())
  barbershopId            String?
  name                    String
  email                   String       @unique
  password                String
  role                    String       @default("BARBER") // Pode ser ADMIN ou BARBER
  isActive                Boolean      @default(true)   // NOVO: Controle de acesso do funcionário
  isVerified              Boolean      @default(false)
  verificationCode        String?
  verificationCodeExpires DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  barbershop Barbershop?  @relation(fields: [barbershopId], references: [id])
  services   ServiceLog[]
}

// ==========================================
// Tabela de Clientes
// ==========================================
model Client {
  id           String   @id @default(cuid())
  barbershopId String?
  name         String
  phone        String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  barbershop   Barbershop? @relation(fields: [barbershopId], references: [id])
  services     ServiceLog[]
}

// ==========================================
// Tabela de Catálogo de Serviços e Preços
// ==========================================
model ServiceType {
  id           String   @id @default(cuid())
  barbershopId String?
  name         String
  price        Float
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  barbershop   Barbershop?  @relation(fields: [barbershopId], references: [id])
  logs         ServiceLog[]
}

// ==========================================
// Tabela de Lançamentos de Serviços
// ==========================================
model ServiceLog {
  id            String   @id @default(cuid())
  barbershopId  String?
  userId        String
  clientId      String
  serviceTypeId String
  priceCharged  Float
  paymentMethod String
  status        String   @default("COMPLETED")
  date          DateTime @default(now())

  barbershop    Barbershop? @relation(fields: [barbershopId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
  client        Client      @relation(fields: [clientId], references: [id])
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id])
}

// ==========================================
// Tabela de Gestão Financeira (Controle de Caixa)
// ==========================================
model FinancialRecord {
  id           String   @id @default(cuid())
  barbershopId String?
  type         String   // INCOME ou EXPENSE
  amount       Float
  description  String
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  barbershop   Barbershop? @relation(fields: [barbershopId], references: [id])
}